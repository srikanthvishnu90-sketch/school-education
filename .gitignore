# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Secrets: NEVER commit ---------------------------------------------------
# Every env file and every credential/key material is ignored. The single
# exception is .env.example, a placeholder-only template (no real values).
.env
.env.*
!.env.example
*.local
# Private keys, certificates, and credential bundles.
*.pem
*.key
*.p12
*.pfx
*.keystore
*.jks
*.asc
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
# Common credential filenames.
secrets.*
*.secret
*.secrets
credentials.json
gha-creds-*.json
service-account*.json
*serviceaccount*.json
.netrc

# tool caches & local working dirs (never commit)
.pnpm-store/
.impeccable/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.gstack/

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
